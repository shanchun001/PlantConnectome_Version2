# MongoDB Atlas connection string (required)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/PlantConnectome?retryWrites=true&w=majority

# OpenAI API key for AI features (validation, summaries)
OPENAI_API_KEY=sk-...

# Groq API key (optional, for alternative LLM summaries)
GROQ_API_KEY=gsk_...

# Flask secret key (auto-generated on Render, set manually for local dev)
SECRET_KEY=change-me-to-a-random-string

# Set to "production" on Render (enables secure cookies, disables debug)
FLASK_ENV=development
